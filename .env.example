# ============================================================
# SAP Ariba MCP Server — Shared Credentials
# ============================================================
# One team member registers an application on the SAP Ariba
# Developer Portal (https://developer.ariba.com) and shares
# this .env file with all 8 team members.
#
# Steps:
# 1. Log in to https://developer.ariba.com
# 2. Register a new application
# 3. Enable the APIs your team needs
# 4. Copy the credentials below
# 5. Share this file securely (never commit to git!)
# ============================================================

# Required — from SAP Ariba Developer Portal
ARIBA_REALM=your-test-realm-T
ARIBA_CLIENT_ID=your-oauth-client-id
ARIBA_CLIENT_SECRET=your-oauth-client-secret
ARIBA_API_KEY=your-application-key

# Optional — override only if using non-standard endpoints
# ARIBA_OAUTH_URL=https://api.ariba.com
# ARIBA_API_URL=https://openapi.ariba.com/api
# ARIBA_REQUEST_TIMEOUT=30
# ARIBA_DEFAULT_PAGE_SIZE=50
